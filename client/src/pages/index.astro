---
import "../styles/global.css";
import { SquarePen, Trash2 } from "@lucide/astro";

const API = import.meta.env.PUBLIC_API_URL || "http://localhost:3000/todos";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>To Do List</title>
  </head>
  <body
    class="bg-gray-100 text-gray-900 flex flex-col items-center justify-start min-h-screen p-10"
  >
    <section
      id="app"
      class="bg-white flex flex-col gap-4 items-center p-6 rounded shadow-md w-full max-w-7xl"
    >
      <h1 class="text-4xl font-bold">Todo App</h1>
      <form id="add-todo-form" class="flex gap-2 w-full">
        <input
          type="text"
          name="task"
          id="task"
          class="flex-1 p-2 border border-gray-300 rounded-lg focus:outline-none focus:ring focus:ring-gray-500/30 focus:border-gray-500/30"
          placeholder="Add a new todo"
          required
        />
        <button
          type="submit"
          id="add-todo-btn"
          class="px-4 py-2 bg-gray-900 text-white rounded-lg text-lg font-semibold cursor-pointer hover:opacity-80 transition-opacity"
          >Add Todo</button
        >
      </form>
      <div id="todos-container" class="flex flex-col gap-2 w-full">
        <!-- Todos will be rendered here -->
      </div>
    </section>
  </body>
  <script is:inline define:vars={{ API }}>
    const $ = (id) => document.getElementById(id);

    const todosContainer = $("todos-container");
    const form = $("add-todo-form");

    /**
     * @component todoCardHTML
     * @description Generates the HTML for a single todo card.
     * @param todo - The todo object containing id and task properties.
     * @returns {string} - The HTML string for the todo card.
     */
    const todoCardHTML = (todo) => `
    <div class="flex items-center gap-4 p-4 border border-gray-300 rounded-lg shadow-sm todo-card">
      <input
        type="checkbox"
        name="${todo.id}"
        id="${todo.id}"
				data-complete="${todo.id}"
				${todo.done ? "checked" : ""}
        class="appearance-none h-5 w-5 border border-gray-900 rounded
            checked:bg-gray-800 checked:border-transparent focus:outline-none
            relative flex items-center justify-center
            checked:after:content-['✓'] checked:after:text-white checked:after:text-sm checked:after:font-bold"
      />
      <label for="${todo.id}" class="text-lg ${todo.done ? "line-through text-gray-900/70" : ""}">${todo.task}</label>
      <div class="ml-auto flex gap-4">
        <button data-edit="${todo.id}" class="cursor-pointer hover:opacity-70 transition-opacity">
          <img src="/square-pen.svg" alt="Edit" class="w-6 h-6" />
        </button>
        <button data-delete="${todo.id}" class="cursor-pointer hover:opacity-70 transition-opacity">
          <img src="/trash-2.svg" alt="Delete" class="w-6 h-6" />
        </button>
      </div>
    </div>`;

    /**
     * @component todoCardEditHTML
     * @description Generates the HTML for a single todo card in edit mode.
     * @param todo - The todo object containing id and task properties.
     * @returns {string} - The HTML string for the todo card in edit mode.
     */
    const todoCardEditHTML = (todo) => `
    <form class="flex items-center gap-2 p-0 w-full todo-card-edit">
			<input
				type="text"
				name="task-edit"
				id="task-edit-${todo.id}"
				value="${todo.task}"
				class="flex-1 p-2 border border-gray-300 rounded-lg focus:outline-none focus:ring focus:ring-gray-500/30 focus:border-gray-500/30"
				placeholder="Task"
				required/>
			<button
				type="submit"
				id="add-todo-btn"
				class="px-4 py-2 bg-gray-900 text-white rounded-lg text-lg font-semibold cursor-pointer hover:opacity-80 transition-opacity"
				>Save</button>
			<button
				id="add-todo-btn"
				class="px-4 py-2 bg-gray-900 text-white rounded-lg text-lg font-semibold cursor-pointer hover:opacity-80 transition-opacity cancel-edit"
				>Cancel</button>
		</form>`;

    /**
     * @function render
     * @description Renders the list of todos in the todosContainer.
     * @param todos - An array of todo objects to be rendered.
     * @returns {void} - Only updates the DOM, does not return a value.
     */
    const render = (todos) => {
      todosContainer.innerHTML = "";

      todos.forEach((todo) => {
        todosContainer.innerHTML += todoCardHTML(todo);
      });
    };

    /**
     * @function handleDelete
     * @description Handles the deletion of a todo item by sending a DELETE request to the API
     * @param id - The ID of the todo item to be deleted
     * @returns {Promise<void>} - A promise that resolves when the todo has been deleted and removed from the DOM
     */
    const handleDelete = async (id) => {
      const res = await fetch(`${API}/${id}`, {
        method: "DELETE",
      });

      if (res.ok) {
        // Remove the todo from the DOM
        const todoElement = document
          .querySelector(`[data-delete="${id}"]`)
          .closest(".todo-card");
        todoElement.remove();
      }
    };

		/**
		 * @function handleEdit
		 * @description Handles the editing of a todo item by replacing the todo card with an edit form and sending a PUT request to the API when the form is submitted.
		 * @param id - The ID of the todo item to be edited
		 * @returns {Promise<void>} - A promise that resolves when the todo has been updated and the DOM has been updated with the new todo card or the original todo card if the edit was canceled
		 */
    const handleEdit = async (id) => {
      const todoElement = document
        .querySelector(`[data-edit="${id}"]`)
        .closest(".todo-card");
      const originalTask = todoElement.querySelector("label").textContent;
      todoElement.innerHTML = todoCardEditHTML({
        id,
        task: originalTask,
      });

      const editForm = todoElement.querySelector(".todo-card-edit");
      editForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const input = editForm.querySelector("input[name='task-edit']");

        const valueTask = input.value.trim();

        if (!valueTask) return;

        const res = await fetch(`${API}/rename/${id}`, {
          method: "PUT",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ task: valueTask }),
        });

        if (res.ok) {
          const updatedTodo = await res.json();
          todoElement.outerHTML = todoCardHTML(updatedTodo);
        }
      });

      const cancelBtn = editForm.querySelector(".cancel-edit");
      cancelBtn.addEventListener("click", (e) => {
        e.preventDefault();
        // Re-render the original todo card
        todoElement.outerHTML = todoCardHTML({
          id,
          task: originalTask,
        });
      });
    };

		const handleToggleComplete = async (id, completed) => {
			const res = await fetch(`${API}/toggle/${id}`, {
				method: "PUT",
			});

			if (res.ok) {
				const updatedTodo = await res.json();
				const todoElement = document
					.querySelector(`[data-complete="${id}"]`)
					.closest(".todo-card");
				todoElement.querySelector("label").textContent = updatedTodo.task;
				todoElement.querySelector("label").classList.toggle("line-through", updatedTodo.done);
				todoElement.querySelector("label").classList.toggle("text-gray-900/70", updatedTodo.done);
			}
		};

    /**
     * @function fetchTodos
     * @description Fetches the list of todos from the API and renders them.
     * @returns {Promise<void>} - A promise that resolves when the todos have been fetched
     */
    const fetchTodos = async () => {
      const res = await fetch(API);
      const todos = await res.json();
      render(todos);
    };

    /**
     * @function handleFormSubmit
     * @description Handles the form submission for adding a new todo.
     * @param {Event} e - The submit event object.
     * @returns {Promise<void>} - A promise that resolves when the new todo has been added and the list has been updated.
     */
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const input = $("task");
      const valueTask = input.value.trim();

      if (!valueTask) return;

      const res = await fetch(`${API}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ task: valueTask }),
      });

      if (res.ok) {
        input.value = "";
        // Preppend the new todo to the list
        const newTodo = await res.json();
        todosContainer.innerHTML =
          todoCardHTML(newTodo) + todosContainer.innerHTML;
      }
    });

    todosContainer.addEventListener("click", async (e) => {
      const target = e.target;

      const btn = target.closest("button");
      if (btn) {
        const todoId = btn.dataset.delete || btn.dataset.edit;

        if (btn.dataset.delete) {
          await handleDelete(todoId);
        }

        if (btn.dataset.edit) {
          await handleEdit(todoId);
        }
        return;
      }

      const checkbox = target.closest("input[data-complete]");
      if (checkbox) {
        const todoId = checkbox.dataset.complete;
        const isCompleted = checkbox.checked;

        await handleToggleComplete(todoId, isCompleted);
      }
    });

    fetchTodos();
  </script>
</html>
